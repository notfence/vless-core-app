#!/bin/sh
set -e

fw_ver="$(sw_vers -productVersion 2>/dev/null || true)"
if [ -z "$fw_ver" ]; then
  fw_ver="$(dpkg-query -W -f='${Version}' firmware 2>/dev/null || true)"
fi
fw_major="${fw_ver%%.*}"
case "$fw_major" in
  ''|*[!0-9]*) fw_major=0 ;;
esac

refresh_uicache() {
  if id mobile >/dev/null 2>&1; then
    su mobile -c "uicache" >/dev/null 2>&1 && return 0
  fi
  uicache >/dev/null 2>&1
}

case "$1" in
  remove|purge)
    echo "Running uicache for package removal..."
    refresh_uicache || true
    if [ "$fw_major" -lt 7 ]; then
      if [ -z "${CYDIA:-}" ]; then
        killall -9 SpringBoard backboardd >/dev/null 2>&1 || true
      fi
    fi
    ;;
esac

exit 0
